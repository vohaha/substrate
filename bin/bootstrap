#!/usr/bin/env bash
set -euo pipefail

# Bootstrap the substrate machine.
# Run as root on a fresh VPS. Idempotent — safe to re-run.
#
# One script, fresh VPS to working system. After this:
#   ssh soma@<IP>  works
#   sudo           works (passwordless)
#   /substrate     exists, owned by soma
#   bun            installed
#   API key        stored (if provided)
#
# Usage: bash bin/bootstrap
#
# Prerequisites: root SSH access, repo already cloned

SUBSTRATE_ROOT="/substrate"
SOMA_USER="soma"

# --- Must be root ---
if [ "$(id -u)" -ne 0 ]; then
    echo "FATAL: Run as root" >&2
    exit 1
fi

echo "=== Substrate Bootstrap ==="

# --- Allow root to operate on soma-owned repo ---
git config --global --add safe.directory "$SUBSTRATE_ROOT" 2>/dev/null || true

# --- System packages ---
echo "Installing system packages..."
if command -v apt-get &>/dev/null; then
    apt-get update -qq
    apt-get install -y -qq git curl jq unzip sudo
elif command -v dnf &>/dev/null; then
    dnf install -y -q git curl jq unzip sudo
else
    echo "FATAL: No supported package manager (need apt or dnf)" >&2
    exit 1
fi
echo "  -> system packages installed"

# --- Create soma user ---
if id "$SOMA_USER" &>/dev/null; then
    echo "  -> user $SOMA_USER exists"
else
    useradd -m -s /bin/bash "$SOMA_USER"
    echo "  -> user $SOMA_USER created"
fi

# --- SSH access for soma (copy root's authorized keys) ---
soma_ssh_dir="/home/$SOMA_USER/.ssh"
if [ -f "$soma_ssh_dir/authorized_keys" ]; then
    echo "  -> soma SSH keys exist"
else
    mkdir -p "$soma_ssh_dir"
    if [ -f /root/.ssh/authorized_keys ]; then
        cp /root/.ssh/authorized_keys "$soma_ssh_dir/authorized_keys"
    fi
    chown -R "$SOMA_USER:$SOMA_USER" "$soma_ssh_dir"
    chmod 700 "$soma_ssh_dir"
    chmod 600 "$soma_ssh_dir/authorized_keys" 2>/dev/null || true
    echo "  -> soma SSH keys configured"
fi

# --- Passwordless sudo for soma ---
sudoers_file="/etc/sudoers.d/$SOMA_USER"
if [ -f "$sudoers_file" ]; then
    echo "  -> soma sudoers exists"
else
    echo "$SOMA_USER ALL=(ALL) NOPASSWD:ALL" > "$sudoers_file"
    chmod 440 "$sudoers_file"
    echo "  -> soma sudoers configured"
fi

# --- Disable root SSH login ---
sshd_config="/etc/ssh/sshd_config"
if [ ! -f "$sshd_config" ]; then
    echo "  -> no sshd_config (container? skipping)"
elif grep -q "^PermitRootLogin no" "$sshd_config" 2>/dev/null; then
    echo "  -> root SSH already disabled"
else
    sed -i 's/^#\?PermitRootLogin.*/PermitRootLogin no/' "$sshd_config"
    systemctl restart sshd 2>/dev/null || systemctl restart ssh 2>/dev/null || true
    echo "  -> root SSH disabled (use soma from now on)"
fi

# --- Set hostname ---
if [ "$(hostname)" = "substrate" ]; then
    echo "  -> hostname already set"
else
    hostnamectl set-hostname substrate 2>/dev/null || hostname substrate 2>/dev/null || echo "  -> hostname change failed (container?)"
    echo "  -> hostname set to substrate"
fi

# --- Bun runtime ---
if su - "$SOMA_USER" -c 'test -x ~/.bun/bin/bun' &>/dev/null; then
    echo "  -> bun $(su - "$SOMA_USER" -c '~/.bun/bin/bun --version') installed"
else
    echo "Installing Bun..."
    su - "$SOMA_USER" -c 'curl -fsSL https://bun.sh/install | bash'
    echo "  -> bun installed for $SOMA_USER"
fi

# --- Ensure /substrate exists and is owned by soma ---
if [ -d "$SUBSTRATE_ROOT/.git" ]; then
    echo "  -> repo exists at $SUBSTRATE_ROOT"
    chown -R "$SOMA_USER:$SOMA_USER" "$SUBSTRATE_ROOT"
else
    echo "WARN: Repo not found at $SUBSTRATE_ROOT" >&2
    echo "  Clone it first, then re-run bootstrap." >&2
    mkdir -p "$SUBSTRATE_ROOT"
    chown "$SOMA_USER:$SOMA_USER" "$SUBSTRATE_ROOT"
fi

# --- Install dependencies ---
if [ -d "$SUBSTRATE_ROOT/.git" ] && [ -f "$SUBSTRATE_ROOT/package.json" ]; then
    echo "Installing dependencies..."
    su - "$SOMA_USER" -c "cd $SUBSTRATE_ROOT && ~/.bun/bin/bun install"
    echo "  -> dependencies installed"
fi

# --- Claude Code memory symlink ---
encoded_path=$(echo "$SUBSTRATE_ROOT" | sed 's|/|-|g')
claude_memory_dir="/home/$SOMA_USER/.claude/projects/${encoded_path}/memory"
repo_memory_dir="$SUBSTRATE_ROOT/memory"

if [ -L "$claude_memory_dir" ] && [ "$(readlink "$claude_memory_dir")" = "$repo_memory_dir" ]; then
    echo "  -> Claude Code memory symlink correct"
elif [ -d "$claude_memory_dir" ]; then
    echo "WARN: Memory directory exists at $claude_memory_dir (not a symlink)" >&2
    echo "  Check for files, then: rm -rf '$claude_memory_dir' && re-run bootstrap" >&2
else
    mkdir -p "$(dirname "$claude_memory_dir")"
    ln -sf "$repo_memory_dir" "$claude_memory_dir"
    chown -R "$SOMA_USER:$SOMA_USER" "/home/$SOMA_USER/.claude"
    echo "  -> Claude Code memory symlink created"
fi

# --- API key storage ---
api_key_dir="/home/$SOMA_USER/.config/substrate"
api_key_file="$api_key_dir/api-key"
mkdir -p "$api_key_dir"
chown -R "$SOMA_USER:$SOMA_USER" "$api_key_dir"
chmod 700 "$api_key_dir"
if [ -f "$api_key_file" ]; then
    echo "  -> API key exists"
else
    echo "  -> Write API key to: $api_key_file"
    echo "     echo 'sk-ant-...' > $api_key_file && chmod 600 $api_key_file"
fi

# --- Verify ---
echo ""
echo "=== Verification ==="
echo -n "git: "; git --version
echo -n "curl: "; curl --version | head -1
echo -n "jq: "; jq --version
echo -n "bun: "; su - "$SOMA_USER" -c '~/.bun/bin/bun --version' 2>/dev/null || echo "not found"
echo "user: $(id "$SOMA_USER")"
echo "hostname: $(hostname)"
echo ""

if [ -f "$api_key_file" ] && [ -d "$SUBSTRATE_ROOT/.git" ]; then
    echo "=== Ready. SSH as soma and run: /substrate/bin/episode reflective-genesis ==="
else
    echo "=== Almost ready. Complete the items above, then run the genesis episode. ==="
fi
